{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "argocd": {
    "fileMatch": ["k8s/apps/[^/]+\\.yaml$", "k8s/bootstrap/.+\\.yaml$"]
  },
  "kubernetes": {
    "fileMatch": ["k8s/apps/.+/.+\\.yaml$", "k8s/infrastructure/.+/.+\\.yaml$"]
  },
  "packageRules": [
    {
      "matchPackageNames": ["longhorn"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "matchPackageNames": ["argo-cd"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchPackageNames": ["ghcr.io/immich-app/postgres"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["^scripts/bootstrap\\.sh$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) registryUrl=(?<registryUrl>\\S+)\\n\\w+_VERSION=\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "fileMatch": ["^\\.github/workflows/.+\\.yml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s+\\w+_VERSION: \"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "fileMatch": ["^proxmox/ansible/playbooks/k3s_bootstrap\\.yml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) registryUrl=(?<registryUrl>\\S+)\\n\\s+\\w+_version: \"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "fileMatch": ["^proxmox/ansible/group_vars/all/vars\\.yml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\nk3s_version: \"(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
