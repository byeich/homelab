[k3s-control]
%{ for name, config in k3s_control_hosts ~}
${name} ansible_host=${config.ip} ansible_user=debian ansible_ssh_private_key_file=~/.ssh/k3s_cluster
%{ endfor ~}

[k3s-workers]
%{ for name, config in k3s_worker_hosts ~}
${name} ansible_host=${config.ip} ansible_user=debian ansible_ssh_private_key_file=~/.ssh/k3s_cluster
%{ endfor ~}
